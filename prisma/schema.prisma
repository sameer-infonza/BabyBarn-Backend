// Internal joins use numeric `id`; clients use `publicId` (cuid) only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PROCESSING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

enum OrderPaymentStatus {
  UNPAID
  PAID
  FAILED
  REFUNDED
}

// Warehouse / carrier pipeline (orthogonal to OrderStatus; do not remove OrderStatus values).
enum OrderFulfillmentStatus {
  NEW_ORDER
  ACCEPTED
  PICKUP_READY
  LABEL_GENERATED
  SHIPPED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
}

enum ReturnType {
  STANDARD
  REFURBISHMENT
}

enum ReturnStatus {
  REQUESTED
  RECEIVED
  UNDER_INSPECTION
  APPROVED
  REJECTED
}

enum StoreCreditTxnType {
  EARNED
  REDEEMED
  ADJUSTED
  HOLD
  RELEASE
}

enum MembershipPaymentType {
  PURCHASE
  RENEWAL
}

enum ProductType {
  NEW
  REFURBISHED
}

enum CancellationReviewStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum ShippingProviderLogLevel {
  INFO
  WARN
  ERROR
}

model Role {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(cuid())
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id         Int      @id @default(autoincrement())
  publicId   String   @unique @default(cuid())
  email      String   @unique
  password   String
  firstName  String?
  lastName   String?
  phone      String?
  roleId     Int
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)

  orders                 Order[]
  addresses              Address[]
  passwordResetTokens    PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  inventoryAdjustments   InventoryAdjustment[]
  returnRequests         ReturnRequest[]
  storeCreditWallet      StoreCreditWallet?
  refreshTokens          RefreshToken[]
  membershipPayments     MembershipPayment[]
  checkoutIntents      CheckoutIntent[]

  stripeCustomerId   String?
  accessNumber       String?   @unique
  babyName           String?
  membershipShippingAddressJson Json?
  accessRenewalReminderSentAt DateTime?
  accessExpiredNoticeSentAt   DateTime?
  accessMemberUntil  DateTime?
  emailVerifiedAt    DateTime?
  // When false, customer cannot sign in.
  isActive           Boolean  @default(true)
  // JSON array of admin console module slugs; null = all modules (ADMIN_TEAM).
  adminModules       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([roleId])
  @@index([publicId])
  @@index([isActive])
  @@index([accessNumber])
}

model MembershipPayment {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(cuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      MembershipPaymentType
  amount    Float
  currency  String   @default("usd")
  stripeSessionId String?
  paidAt    DateTime @default(now())
  accessValidUntil DateTime?

  @@index([userId])
  @@index([paidAt])
  @@index([stripeSessionId])
}

model EmailVerificationToken {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(cuid())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  publicId  String    @unique @default(cuid())
  token     String    @unique
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([token])
}

model Address {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(cuid())
  userId    Int
  fullName  String?
  addressLine1 String?
  addressLine2 String?
  street    String
  city      String
  state     String
  zipCode   String
  country   String
  phoneNumber String?
  isDefault Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Category {
  id          Int        @id @default(autoincrement())
  publicId    String     @unique @default(cuid())
  name        String
  slug        String
  description String?
  parentId    Int?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children    Category[] @relation("CategoryTree")
  isActive    Boolean    @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([parentId, name])
  @@unique([parentId, slug])
  @@index([parentId])
}

model Product {
  id          Int      @id @default(autoincrement())
  publicId    String   @unique @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       Float
  stock         Int @default(0)
  reservedStock Int @default(0)
  categoryId  Int
  imageUrl    String?
  sku         String   @unique

  memberPrice          Float?
  compareAtPrice       Float?
  unitPriceAmount      Float?
  unitPriceReference   String?
  fabric               String?
  care                 String?
  sizeAgeGroup         String?
  vendor               String?
  tags                 String?
  isDraft              Boolean  @default(false)
  isActiveListing      Boolean  @default(true)
  inventoryModel       String      @default("simple")
  gallery              Json?
  productType          ProductType @default(NEW)

  category   Category                @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  checkoutIntentLines CheckoutIntentLine[]
  variants   ProductVariant[]
  inventoryAdjustments InventoryAdjustment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([slug])
  @@index([publicId])
  @@index([isDraft])
  @@index([productType])
}

model ProductVariant {
  id            Int      @id @default(autoincrement())
  publicId      String   @unique @default(cuid())
  productId     Int
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  combination   Json
  sku           String
  stock         Int @default(0)
  reservedStock Int @default(0)
  stockVersion  Int @default(0)
  priceOverride Float?
  imageUrl      String?
  sortOrder     Int      @default(0)

  inventoryAdjustments InventoryAdjustment[]
  orderItems           OrderItem[]
  checkoutIntentLines  CheckoutIntentLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, sku])
  @@index([productId])
}

enum CheckoutIntentStatus {
  PENDING
  CONSUMED
  EXPIRED
  FAILED
}

/// In-progress checkout (stock/credit held). Becomes an Order only after payment succeeds.
model CheckoutIntent {
  id                      Int                  @id @default(autoincrement())
  publicId                String               @unique @default(cuid())
  userId                  Int
  status                  CheckoutIntentStatus @default(PENDING)
  checkoutSignature       String
  subtotal                Float
  shippingCost            Float                @default(0)
  storeCreditApplied      Float                @default(0)
  totalAmount             Float
  shippingAddressJson     Json?
  billingAddressJson      Json?
  shippingCarrier         String?
  shippingShipmentId      String?
  selectedRateId          String?
  selectedRateProvider    String?
  selectedRateServiceLevel String?
  selectedRateServiceToken String?
  selectedRateAmount      Float?
  selectedRateCurrency    String?
  selectedRateEstimatedDays Int?
  stripePaymentIntentId   String?              @unique
  orderPublicId           String?              @unique
  expiresAt               DateTime?

  user  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  lines CheckoutIntentLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([checkoutSignature])
  @@index([createdAt])
}

model CheckoutIntentLine {
  id               Int     @id @default(autoincrement())
  checkoutIntentId Int
  productId        Int
  productVariantId Int?
  quantity         Int
  price            Float

  checkoutIntent CheckoutIntent @relation(fields: [checkoutIntentId], references: [id], onDelete: Cascade)
  product        Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  @@index([checkoutIntentId])
  @@index([productId])
}

model Order {
  id          Int         @id @default(autoincrement())
  publicId    String      @unique @default(cuid())
  /// Customer-facing reference, e.g. BB-000042 (not the API publicId).
  orderNumber String      @unique
  userId      Int
  status      OrderStatus @default(PENDING)
  /// Fulfillment pipeline; null until order is paid (then usually NEW_ORDER).
  fulfillmentStatus    OrderFulfillmentStatus?
  packageDetailsJson   Json?
  manualShippingNotes  String?  @db.Text
  deliveredAt          DateTime?
  fulfillmentAcceptedAt DateTime?
  pickupReadyAt        DateTime?
  labelGeneratedAt     DateTime?
  outboundShippedAt    DateTime?
  totalAmount Float
  shippingCost Float @default(0)
  shippingAddressJson Json?
  billingAddressJson Json?
  shippingCarrier String?
  trackingNumber String?
  // UPS / carrier label PDF or print URL (set by admin).
  shippingLabelUrl String?
  selectedRateId String?
  selectedRateProvider String?
  selectedRateServiceLevel String?
  selectedRateServiceToken String?
  selectedRateAmount Float?
  selectedRateCurrency String?
  selectedRateEstimatedDays Int?
  shippingShipmentId String?
  shippingTransactionId String?
  returnShipmentId String?
  returnLabelUrl String?
  returnTrackingNumber String?
  returnShippingCarrier String?
  returnTransactionId String?
  trackingStatus String?
  trackingStatusDetails String?
  trackingStatusDate DateTime?
  trackingEta DateTime?
  trackingHistoryJson Json?
  paymentStatus            OrderPaymentStatus @default(PAID)
  stripeCheckoutSessionId  String?            @unique
  stripePaymentIntentId    String?            @unique
  storeCreditApplied       Float              @default(0)

  cancellationReviewStatus  CancellationReviewStatus @default(NONE)
  cancellationRequestedAt   DateTime?
  cancellationRequestReason String?
  cancellationReviewNote    String?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  returnRequests ReturnRequest[]
  trackingEvents ShipmentTrackingEvent[]
  pickupListLines PickupListLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([fulfillmentStatus])
  @@index([publicId])
  @@index([orderNumber])
  @@index([paymentStatus])
  @@index([cancellationReviewStatus])
}

model ShipmentTrackingEvent {
  id            Int      @id @default(autoincrement())
  publicId      String   @unique @default(cuid())
  orderId       Int
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  source        String   @default("ups")
  statusCode    String?
  description   String?  @db.Text
  location      String?
  raw           Json?
  eventAt       DateTime?
  createdAt     DateTime @default(now())

  @@index([orderId, createdAt])
}

model PickupList {
  id        Int      @id @default(autoincrement())
  publicId String   @unique @default(cuid())
  title     String?
  createdAt DateTime @default(now())
  lines     PickupListLine[]
}

model PickupListLine {
  id           Int        @id @default(autoincrement())
  publicId     String     @unique @default(cuid())
  pickupListId Int
  orderId      Int
  sortOrder    Int        @default(0)
  pickupList   PickupList @relation(fields: [pickupListId], references: [id], onDelete: Cascade)
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([pickupListId, orderId])
  @@index([orderId])
}

/// Singleton id=1 — operational shipping defaults (non-secret flags + JSON blobs).
model ShippingSettings {
  id                       Int      @id @default(1)
  pickupAddressJson        Json?
  defaultPackageJson       Json?
  autoLabelGeneration      Boolean  @default(false)
  manualShippingAllowed    Boolean  @default(true)
  updatedAt                DateTime @updatedAt
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  publicId String  @unique @default(cuid())
  orderId   Int
  productId Int
  productVariantId Int?
  quantity  Int
  price     Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  returnRequests ReturnRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([productVariantId])
}

model ReturnRequest {
  id Int @id @default(autoincrement())
  publicId String @unique @default(cuid())
  userId Int
  orderId Int
  orderItemId Int?
  type ReturnType @default(STANDARD)
  status ReturnStatus @default(REQUESTED)
  reason String?
  notes String?
  creditAwarded Float @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([orderId])
  @@index([status])
}

model AdminAuditLog {
  id         Int    @id @default(autoincrement())
  publicId   String @unique @default(cuid())
  actorId    String?
  actorEmail String?
  action     String
  entityType String
  entityId   String
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// Singleton row (id = 1) for editable business defaults (e.g. ACCESS price).
model BusinessSettings {
  id                        Int      @id @default(1)
  accessMembershipPriceUsd  Float    @default(50)
  updatedAt                 DateTime @updatedAt
}

// Configurable shipping carrier integration (UPS, Shippo, future providers).
model ShippingProvider {
  id                     Int      @id @default(autoincrement())
  publicId               String   @unique @default(cuid())
  slug                   String   @unique
  displayName            String
  enabled                Boolean  @default(true)
  isDefault              Boolean  @default(false)
  sortOrder              Int      @default(0)
  // AES-GCM encrypted JSON (base64); optional when env keys are used.
  credentialsEncrypted   String?  @db.Text
  metadata               Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  services ShippingServiceMethod[]

  @@index([enabled])
  @@index([sortOrder])
}

// Admin-toggled methods; Shippo uses code "*" for all marketplace rates.
model ShippingServiceMethod {
  id                Int      @id @default(autoincrement())
  publicId          String   @unique @default(cuid())
  providerId        Int
  provider          ShippingProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  code              String
  displayName       String
  enabled           Boolean  @default(true)
  visibleAtCheckout Boolean  @default(true)
  visibleInAdmin    Boolean  @default(true)
  sortOrder         Int      @default(0)
  rules             Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([providerId, code])
  @@index([providerId])
}

model ShippingProviderLog {
  id            Int                     @id @default(autoincrement())
  providerSlug  String
  level         ShippingProviderLogLevel @default(INFO)
  action        String
  orderPublicId String?
  message       String                  @db.Text
  details       Json?
  createdAt     DateTime                @default(now())

  @@index([providerSlug, createdAt])
  @@index([createdAt])
}

model StoreCreditWallet {
  id Int @id @default(autoincrement())
  publicId String @unique @default(cuid())
  userId Int @unique
  balance Float @default(0)
  heldBalance Float @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions StoreCreditTransaction[]
}

model StoreCreditTransaction {
  id Int @id @default(autoincrement())
  publicId String @unique @default(cuid())
  walletId Int
  type StoreCreditTxnType
  amount Float
  note String?
  orderPublicId String?
  createdAt DateTime @default(now())

  wallet StoreCreditWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([orderPublicId])
}

model StripeWebhookEvent {
  id Int @id @default(autoincrement())
  eventId String @unique
  type String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

model RefreshToken {
  id Int @id @default(autoincrement())
  publicId String @unique @default(cuid())
  userId Int
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model InventoryAdjustment {
  id               Int             @id @default(autoincrement())
  publicId         String          @unique @default(cuid())
  productId        Int
  product          Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariantId Int?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  userId           Int
  user             User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  quantityChange   Int
  reason           String?
  createdAt        DateTime        @default(now())

  @@index([productId])
  @@index([productVariantId])
  @@index([userId])
  @@index([createdAt])
}
