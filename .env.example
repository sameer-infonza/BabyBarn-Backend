DATABASE_URL=postgresql://user:password@localhost:5432/ecommerce
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=7d
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
# Used to build password-reset links (optional; defaults to http://localhost:3000)
FRONTEND_URL=http://localhost:3000
# Default role assigned during registration
DEFAULT_ROLE=CUSTOMER
# Super admin (scripts/seed.js): created once; re-runs do not reset password
# In production, set both; otherwise super admin user is not created
SUPER_ADMIN_EMAIL=admin@babyburn.local
SUPER_ADMIN_PASSWORD=
# Optional
# SUPER_ADMIN_FIRST_NAME=Super
# SUPER_ADMIN_LAST_NAME=Admin
# Set true to only seed roles
# SKIP_SUPER_ADMIN_SEED=false
# Set true behind AWS ALB/CloudFront/reverse proxies
TRUST_PROXY=false
# For AWS RDS PostgreSQL, use a URL like:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
#
# API: same JSON routes under /api and /api/v1 (use /api/v1 for mobile apps).
