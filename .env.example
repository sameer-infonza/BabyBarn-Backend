DATABASE_URL=postgresql://user:password@localhost:5432/ecommerce
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=7d
PORT=5000
NODE_ENV=development
# Comma-separated browser origins (store + admin frontends), e.g. http://localhost:3000,http://admin.localhost:3000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
# Optional split variables (also comma-separated). Combined with CORS_ORIGIN.
FRONTEND_USER_URLS=http://localhost:3000,https://www.babyburn.com
FRONTEND_ADMIN_URLS=http://localhost:3001,https://admin.babyburn.com
# Customer-facing site URL (Stripe success/cancel redirects)
STORE_PUBLIC_URL=http://localhost:3000
# Stripe Connect — platform secret; webhook signing secret from Dashboard
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Connected account IDs (acct_...) — membership fees vs product sales
STRIPE_CONNECT_ACCOUNT_MEMBERSHIP=
STRIPE_CONNECT_ACCOUNT_STORE=
# ACCESS membership length after one-time $50 payment (days)
ACCESS_MEMBERSHIP_DAYS=365
# Used to build password-reset/verification links
FRONTEND_URL=http://localhost:3000
CUSTOMER_FRONTEND_URL=http://localhost:3000
ADMIN_FRONTEND_URL=http://localhost:3001
# SMTP (set for reliable email delivery in non-dev envs)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM=Baby Barn <no-reply@babyburn.com>
CUSTOMER_FRONTEND_URL=http://localhost:3000
ADMIN_FRONTEND_URL=http://localhost:3001
# SMTP (set for reliable email delivery in non-dev envs)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM=Baby Barn <no-reply@babyburn.com>
# Default role assigned during registration
DEFAULT_ROLE=CUSTOMER
# Seed users are defined in backend/scripts/seed.js (idempotent).
# No user credentials should be stored in environment variables.
# Set true behind AWS ALB/CloudFront/reverse proxies
TRUST_PROXY=false
# For AWS RDS PostgreSQL, use a URL like:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
#
# API: same JSON routes under /api and /api/v1 (use /api/v1 for mobile apps).

# Shippo shipping provider
SHIPPO_API_KEY=
SHIPPO_BASE_URL=https://api.goshippo.com
SHIPPO_TIMEOUT_MS=12000
SHIPPO_WEBHOOK_SECRET=

# Default origin address (used for rates/shipments)
SHIP_FROM_NAME=Baby Barn Warehouse
SHIP_FROM_COMPANY=Baby Barn
SHIP_FROM_STREET1=
SHIP_FROM_STREET2=
SHIP_FROM_CITY=
SHIP_FROM_STATE=
SHIP_FROM_ZIP=
SHIP_FROM_COUNTRY=US
SHIP_FROM_PHONE=
SHIP_FROM_EMAIL=

# Default parcel fallback when checkout does not send parcel dimensions
SHIP_DEFAULT_PARCEL_LENGTH=10
SHIP_DEFAULT_PARCEL_WIDTH=8
SHIP_DEFAULT_PARCEL_HEIGHT=4
SHIP_DEFAULT_DISTANCE_UNIT=in
SHIP_DEFAULT_WEIGHT=1
SHIP_DEFAULT_MASS_UNIT=lb
