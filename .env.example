DATABASE_URL=postgresql://user:password@localhost:5432/ecommerce
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=7d
PORT=5000
NODE_ENV=development
# Comma-separated browser origins (store + admin frontends), e.g. http://localhost:3000,http://admin.localhost:3000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
# Optional split variables (also comma-separated). Combined with CORS_ORIGIN.
FRONTEND_USER_URLS=http://localhost:3000,https://www.babyburn.com
FRONTEND_ADMIN_URLS=http://localhost:3001,https://admin.babyburn.com
# Customer-facing site URL (Stripe success/cancel redirects)
STORE_PUBLIC_URL=http://localhost:3000
# Stripe Connect — platform secret; webhook signing secret from Dashboard
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Connected account IDs (acct_...) — membership fees vs product sales
STRIPE_CONNECT_ACCOUNT_MEMBERSHIP=
STRIPE_CONNECT_ACCOUNT_STORE=
# ACCESS membership length after one-time $50 payment (days)
ACCESS_MEMBERSHIP_DAYS=365
# Used to build password-reset links (optional; defaults to http://localhost:3000)
FRONTEND_URL=http://localhost:3000
# Default role assigned during registration
DEFAULT_ROLE=CUSTOMER
# Seed users are defined in backend/scripts/seed.js (idempotent).
# No user credentials should be stored in environment variables.
# Set true behind AWS ALB/CloudFront/reverse proxies
TRUST_PROXY=false
# For AWS RDS PostgreSQL, use a URL like:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
#
# API: same JSON routes under /api and /api/v1 (use /api/v1 for mobile apps).
